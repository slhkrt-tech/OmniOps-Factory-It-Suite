# OmniOps Ortam Değişkenleri
# Gerçek değerleri gizli tutmak için bu dosyayı .env olarak kopyalayın.

APP_NAME=OmniOps
DJANGO_SECRET_KEY=replace-with-at-least-64-random-characters-generated-by-your-password-manager
DJANGO_DEBUG=False
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_PRELOAD=True
ALLOWED_HOSTS=localhost,127.0.0.1,omniops.example.com
CSRF_TRUSTED_ORIGINS=https://omniops.example.com
DJANGO_LOG_LEVEL=INFO
SESSION_COOKIE_AGE=28800
FILE_UPLOAD_MAX_MEMORY_SIZE=5242880
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760

# Database
POSTGRES_DB=omniops
POSTGRES_USER=omniops
POSTGRES_PASSWORD=omniops
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgres://omniops:omniops@db:5432/omniops

# Celery & Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Gunicorn
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120
GUNICORN_MAX_REQUESTS=1000

# Güvenlik & Webhook
WAZUH_API_KEY=replace-with-random-webhook-key
WEBHOOK_ALLOWED_IPS=127.0.0.1,::1
VAULT_KEY=replace-with-fernet-key-generated-for-this-installation

# --- YENİ: PostgreSQL S3 Yedekleme ---
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BACKUP_BUCKET=omniops-backups
AWS_S3_REGION_NAME=eu-central-1
POSTGRES_BACKUP_DIR=/app/db_backups
POSTGRES_BACKUP_FORMAT=custom
POSTGRES_BACKUP_FILE_PREFIX=omniops_backup

# --- YENİ: Dağıtık Probe (Agent) ---
REMOTE_PROBE_SHARED_SECRET=your_super_secret_probe_key

# --- YENİ: SSO (Azure AD / OIDC / SAML) ---
# Azure AD
SOCIAL_AUTH_AZUREAD_OAUTH2_KEY=your_azure_client_id
SOCIAL_AUTH_AZUREAD_OAUTH2_SECRET=your_azure_client_secret
SOCIAL_AUTH_AZUREAD_OAUTH2_TENANT_ID=your_tenant_id

# Active Directory / LDAP Operasyon Merkezi
LDAP_ENABLED=False
LDAP_SERVER_URI=ldap://dc01.example.local
LDAP_BASE_DN=DC=example,DC=local
LDAP_BIND_USERNAME=EXAMPLE\svc_omniops
LDAP_BIND_PASSWORD=replace-with-directory-bind-password
LDAP_USER_FILTER=(objectClass=user)
LDAP_GROUP_FILTER=(objectClass=group)
DIRECTORY_SYNC_DRY_RUN=False
ALLOW_PUBLIC_REGISTRATION=False
SITE_ACCESS_ENFORCEMENT=True
FEATURE_SALES_KANBAN=True
WORKSPACE_PRIMARY_INDUSTRY=generic
PROMETHEUS_METRICS_ENABLED=True
PROMETHEUS_METRICS_TOKEN=

# OnlyOffice Document Server (DOCX/XLSX tarayıcı editörü)
ONLYOFFICE_DOCUMENT_SERVER_URL=
ONLYOFFICE_JWT_SECRET=
# Collabora Online alternatif editör (WOPI)
COLLABORA_SERVER_URL=
DOCUMENT_EDITOR_BACKEND=auto
WOPI_SECRET=

# OIDC (General)
SOCIAL_AUTH_OIDC_KEY=your_oidc_client_id
SOCIAL_AUTH_OIDC_SECRET=your_oidc_client_secret
SOCIAL_AUTH_OIDC_ENDPOINT=https://your-oidc-provider/.well-known/openid-configuration

# SAML (Opsiyonel)
SAML_METADATA_URL=https://idp.example.com/saml/metadata
SAML_ENTITY_ID=https://omniops.example.com/saml2/metadata/
SAML_ACS_URL=https://omniops.example.com/accounts/complete/saml/

# E-posta Ayarları
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
ADMINS=Admin:admin@yourdomain.com